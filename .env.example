# ====== poll-engine env (communities-tools) ======

# Supabase — publiek (frontend, anon-client; leest uitsluitend OPEN polls/vragen via RLS)
# Project: communities-tools
NEXT_PUBLIC_SUPABASE_URL=https://mqkhfyvrizgmmmcbdkxh.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server-only (service role; voor vote/results/export/admin routes)
# NOOIT met NEXT_PUBLIC_ prefix; nooit naar de client lekken.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Salt voor de HMAC-SHA256 IP-hash (server-only). Genereer iets willekeurigs & lang.
POLL_IP_SALT=change-me-to-a-long-random-string

# Beheer-secret voor /admin/polls (v1). Vervang later door de bestaande communities-tools SSO/HMAC.
ADMIN_SECRET=change-me-admin-password
